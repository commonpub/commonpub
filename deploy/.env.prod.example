# ===========================================
# CommonPub Production Environment Variables
# ===========================================

# ---- Core ----
# The Nuxt app reads NUXT_-prefixed runtimeConfig keys; bare equivalents (ORIGIN,
# DATABASE_URL, AUTH_SECRET, SMTP_*, EMAIL_ADAPTER …) do NOT reach the running app.
# (MEILI_*, S3_*, FEATURE_*, and UPLOAD_DIR are the exceptions — read from process.env directly.)
NUXT_PUBLIC_SITE_URL=https://your-domain.com
PORT=3000

# ---- Database ----
POSTGRES_PASSWORD=change-me-strong-password
# Set NUXT_DATABASE_URL explicitly (docker-compose.prod.yml does NOT auto-compose it):
NUXT_DATABASE_URL=postgresql://commonpub:change-me-strong-password@postgres:5432/commonpub

# ---- Redis ----
# The Redis container starts automatically from docker-compose.prod.yml with
# --requirepass $REDIS_PASSWORD. You MUST set a password below or the default
# "changeme" will be used.
REDIS_PASSWORD=change-me-generate-with-openssl-rand-base64-24
#
# NUXT_REDIS_URL is what the app reads. UNSET it to keep running on the
# in-process rate-limit + SSE defaults (fine for a single droplet — no data
# travels over Redis). SET it to enable horizontal scaling (cross-process
# rate limits + SSE fanout). See codebase-analysis/12-scaling-and-infrastructure.md
# for when to flip it and how to verify.
#
# NUXT_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ---- Auth ----
# Generate with: openssl rand -base64 32
NUXT_AUTH_SECRET=change-me-min-32-chars

# ---- Meilisearch ----
# MEILI_URL is read directly from the environment (NOT auto-composed). Set it to
# point at the meilisearch service; leave unset to fall back to Postgres FTS.
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=generate-a-strong-key

# ---- Instance Identity ----
NUXT_PUBLIC_DOMAIN=your-domain.com
NUXT_PUBLIC_SITE_NAME=My CommonPub Instance
NUXT_PUBLIC_SITE_DESCRIPTION=A maker community

# ---- Feature Flags (read directly from env; 19 FEATURE_* keys — see docs/deployment.md) ----
FEATURE_ADMIN=true
FEATURE_FEDERATION=false
FEATURE_HUBS=true
FEATURE_DOCS=true
FEATURE_LEARNING=true
FEATURE_EXPLAINERS=true

# ---- OAuth Providers (optional) ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Email (optional — SMTP or Resend) ----
# NUXT_EMAIL_ADAPTER selects the transport: console (default), smtp, or resend.
NUXT_EMAIL_ADAPTER=console
NUXT_SMTP_HOST=
NUXT_SMTP_PORT=587
NUXT_SMTP_USER=
NUXT_SMTP_PASS=
NUXT_SMTP_FROM=noreply@your-domain.com
NUXT_RESEND_API_KEY=

# ---- Storage (S3-compatible — DO Spaces, MinIO, AWS S3) ----
# If S3_BUCKET is empty, uploads go to local filesystem (./uploads/)
S3_BUCKET=
S3_REGION=nyc3
# DO Spaces: https://<region>.digitaloceanspaces.com
# MinIO: http://localhost:9000
# AWS S3: leave blank (uses default)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Public URL for uploaded files. Auto-derived if not set.
# DO Spaces CDN: https://<bucket>.<region>.cdn.digitaloceanspaces.com
S3_PUBLIC_URL=
# Set to true for MinIO (path-style access)
S3_FORCE_PATH_STYLE=false
# Local uploads directory (when not using S3) — read directly from process.env (bare, no NUXT_)
UPLOAD_DIR=./uploads

# ---- Analytics (optional) ----
PLAUSIBLE_URL=
PLAUSIBLE_DOMAIN=
