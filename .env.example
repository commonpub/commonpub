# ===========================================
# CommonPub Development Environment Variables
# ===========================================
# Copy to .env and adjust values as needed.
# Ports match root docker-compose.yml defaults (5433/6380/7701).

# ---- Database ----
# Root docker-compose.yml maps host:5433 → container:5432.
# The running app reads NUXT_DATABASE_URL (Nuxt runtimeConfig only picks up NUXT_-prefixed
# env). drizzle-kit (db:generate) reads bare DATABASE_URL, and db-migrate.mjs reads
# NUXT_DATABASE_URL || DATABASE_URL — so set BOTH to the same value for local dev.
NUXT_DATABASE_URL=postgresql://commonpub:commonpub_dev@localhost:5433/commonpub
DATABASE_URL=postgresql://commonpub:commonpub_dev@localhost:5433/commonpub

# ---- Redis (optional — horizontal scaling only) ----
# UNSET = in-process rate-limit + SSE (fine for single-instance dev).
# SET = cross-process Redis rate-limit + SSE pub/sub. The dev compose
# exposes Redis at host:6380, so the line below is commented out by
# default. Uncomment if you want to test the Redis path locally.
# NUXT_REDIS_URL=redis://localhost:6380

# ---- Meilisearch ----
# Root docker-compose.yml maps host:7701 → container:7700
MEILI_URL=http://localhost:7701
MEILI_MASTER_KEY=commonpub_dev_key

# ---- Auth ----
# Read via runtimeConfig.authSecret — must be NUXT_-prefixed (bare AUTH_SECRET is ignored;
# in production the app refuses to boot on the default dev secret).
NUXT_AUTH_SECRET=change-me-in-production-min-32-chars

# ---- Nuxt Runtime ----
# NUXT_PUBLIC_SITE_URL is used by useSeoMeta / useHead, and Better Auth derives
# its baseURL (auth callback origin) from it — there is no separate AUTH_ORIGIN var.
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- OAuth Providers (optional — graceful degradation if not set) ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Email ----
# Read via runtimeConfig, so these are NUXT_-prefixed (bare names are ignored by Nuxt).
# Adapter: "console" (dev, logs to terminal), "smtp" (nodemailer), or "resend" (Resend API)
NUXT_EMAIL_ADAPTER=console
# SMTP settings (when NUXT_EMAIL_ADAPTER=smtp)
# NUXT_SMTP_HOST=smtp.example.com
# NUXT_SMTP_PORT=587
# NUXT_SMTP_USER=
# NUXT_SMTP_PASS=
# NUXT_SMTP_FROM=noreply@localhost:3000
# Resend settings (when NUXT_EMAIL_ADAPTER=resend)
# NUXT_RESEND_API_KEY=re_...
# NUXT_RESEND_FROM=noreply@localhost:3000

# ---- Storage (S3-compatible) ----
# When S3_BUCKET is set, uses S3 storage. Otherwise, local filesystem.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=
S3_FORCE_PATH_STYLE=false
# Local upload directory (used when S3_BUCKET is not set)
UPLOAD_DIR=./uploads

# ---- Instance Identity ----
# Read via runtimeConfig.public.* (NUXT_PUBLIC_-prefixed); bare INSTANCE_* are NOT read.
# These override the hardcoded defaults in commonpub.config.ts at runtime.
NUXT_PUBLIC_DOMAIN=localhost:3000
NUXT_PUBLIC_SITE_NAME=CommonPub Dev
NUXT_PUBLIC_SITE_DESCRIPTION=Local development instance

# ---- Analytics (Plausible) ----
PLAUSIBLE_URL=
PLAUSIBLE_DOMAIN=

# ---- Feature Flags ----
# Server-side (read by server/utils/config.ts) — 19 FEATURE_* keys.
# (publicApi, layoutEngine, rbac and identity.* have NO env key — set them in commonpub.config.ts.)
FEATURE_CONTENT=true
FEATURE_SOCIAL=true
FEATURE_HUBS=true
FEATURE_DOCS=true
FEATURE_VIDEO=true
FEATURE_LEARNING=true
FEATURE_EXPLAINERS=true
FEATURE_EDITORIAL=true
FEATURE_CONTENT_IMPORT=true
FEATURE_CONTESTS=false
FEATURE_EVENTS=false
FEATURE_ADMIN=false
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_FEDERATION=false
FEATURE_FEDERATE_HUBS=false
FEATURE_SEAMLESS_FEDERATION=false
FEATURE_ACT_AS_REGISTRY=false
FEATURE_ANNOUNCE_TO_REGISTRY=true
FEATURE_PUBLIC_API_METRICS_FEDERATION=false

# Client-side (read by Nuxt runtimeConfig.public — override with NUXT_PUBLIC_FEATURES_*)
# These mirror the server flags. Nuxt maps NUXT_PUBLIC_FEATURES_HUBS=false automatically.
# NUXT_PUBLIC_FEATURES_CONTENT=true
# NUXT_PUBLIC_FEATURES_HUBS=true
# NUXT_PUBLIC_FEATURES_DOCS=true
# etc.

# Content types (comma-separated; valid: project, blog, explainer; `article` is a
# deprecated alias that normalizes to blog on write — prefer blog)
# NUXT_PUBLIC_CONTENT_TYPES=project,blog,explainer

# Contest creation permission: open, staff, or admin
# NUXT_PUBLIC_CONTEST_CREATION=admin
