# ===========================================
# CommonPub Development Environment Variables
# ===========================================
# Copy to .env and adjust values as needed.
# Ports match root docker-compose.yml defaults (5433/6380/7701).

# ---- Database ----
# Root docker-compose.yml maps host:5433 → container:5432
DATABASE_URL=postgresql://commonpub:commonpub_dev@localhost:5433/commonpub

# ---- Redis ----
# Root docker-compose.yml maps host:6380 → container:6379
REDIS_URL=redis://localhost:6380

# ---- Meilisearch ----
# Root docker-compose.yml maps host:7701 → container:7700
MEILI_URL=http://localhost:7701
MEILI_MASTER_KEY=commonpub_dev_key

# ---- Auth ----
AUTH_SECRET=change-me-in-production-min-32-chars

# ---- Nuxt Runtime ----
# NUXT_PUBLIC_SITE_URL is used by useSeoMeta / useHead
NUXT_PUBLIC_SITE_URL=http://localhost:3000
# Origin for Better Auth callbacks
NUXT_AUTH_ORIGIN=http://localhost:3000

# ---- OAuth Providers (optional — graceful degradation if not set) ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Email ----
# Adapter: "console" (dev, logs to terminal), "smtp" (nodemailer), or "resend" (Resend API)
EMAIL_ADAPTER=console
# SMTP settings (when EMAIL_ADAPTER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@localhost:3000
# Resend settings (when EMAIL_ADAPTER=resend)
# RESEND_API_KEY=re_...
# RESEND_FROM=noreply@localhost:3000

# ---- Storage (S3-compatible) ----
# When S3_BUCKET is set, uses S3 storage. Otherwise, local filesystem.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=
S3_FORCE_PATH_STYLE=false
# Local upload directory (used when S3_BUCKET is not set)
UPLOAD_DIR=./uploads

# ---- Instance Identity ----
INSTANCE_DOMAIN=localhost:3000
INSTANCE_NAME=CommonPub Dev
INSTANCE_DESCRIPTION=Local development instance

# ---- Analytics (Plausible) ----
PLAUSIBLE_URL=
PLAUSIBLE_DOMAIN=

# ---- Feature Flags (override defaults from commonpub.config.ts) ----
FEATURE_COMMUNITIES=true
FEATURE_DOCS=true
FEATURE_LEARNING=true
FEATURE_EXPLAINERS=true
FEATURE_ADMIN=false
FEATURE_FEDERATION=false
# FEATURE_VIDEO=true
# FEATURE_CONTESTS=false
