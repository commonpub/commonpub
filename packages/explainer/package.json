{
  "name": "@commonpub/explainer",
  "version": "0.7.12",
  "type": "module",
  "description": "Interactive explainer runtime + Vue components — standalone, framework-agnostic engine with optional Vue 3 UI",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/commonpub/commonpub",
    "directory": "packages/explainer"
  },
  "keywords": [
    "commonpub",
    "explainer",
    "interactive",
    "quiz",
    "vue",
    "components"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vue": {
      "import": "./vue/index.ts"
    },
    "./vue/theme": {
      "import": "./vue/theme/base.css"
    },
    "./vue/theme/explainer-themes.css": "./vue/theme/explainer-themes.css",
    "./vue/theme/dark-industrial.css": "./vue/theme/dark-industrial.css",
    "./vue/theme/punk-zine.css": "./vue/theme/punk-zine.css",
    "./vue/theme/paper-teal.css": "./vue/theme/paper-teal.css",
    "./vue/theme/clean-light.css": "./vue/theme/clean-light.css"
  },
  "files": [
    "dist/",
    "vue/",
    "modules/",
    "!dist/__tests__/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build",
    "playground": "vite --config playground/vite.config.ts",
    "story:dev": "histoire dev",
    "story:build": "histoire build"
  },
  "dependencies": {
    "@commonpub/config": "workspace:*",
    "@commonpub/editor": "workspace:*",
    "@commonpub/schema": "^0.14.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@histoire/plugin-vue": "^0.17.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "histoire": "^0.17.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.1",
    "vitest": "^3.0.0",
    "vue": "^3.5.0"
  }
}
