{
  "name": "@commonpub/editor",
  "version": "0.1.0",
  "type": "module",
  "description": "TipTap block editor with 18+ maker-focused extensions for CommonPub",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/commonpub/commonpub",
    "directory": "packages/editor"
  },
  "keywords": ["commonpub", "activitypub", "federation", "typescript", "tiptap", "block-editor", "rich-text"],
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=22" },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist/", "!dist/__tests__/", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@commonpub/config": "workspace:*",
    "@commonpub/schema": "workspace:*",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@tiptap/core": "^2.11.0",
    "@tiptap/extension-bold": "^2.11.0",
    "@tiptap/extension-code": "^2.11.0",
    "@tiptap/extension-document": "^2.11.0",
    "@tiptap/extension-history": "^2.11.0",
    "@tiptap/extension-italic": "^2.11.0",
    "@tiptap/extension-link": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0",
    "@tiptap/extension-strike": "^2.11.0",
    "@tiptap/extension-bullet-list": "^2.11.0",
    "@tiptap/extension-ordered-list": "^2.11.0",
    "@tiptap/extension-list-item": "^2.11.0",
    "@tiptap/extension-horizontal-rule": "^2.11.0",
    "@tiptap/extension-text": "^2.11.0",
    "@tiptap/pm": "^2.11.0"
  },
  "devDependencies": {
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
