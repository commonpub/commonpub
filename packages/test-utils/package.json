{
  "name": "@commonpub/test-utils",
  "version": "0.1.0",
  "type": "module",
  "description": "Test factories and mock config for CommonPub development",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/commonpub/commonpub",
    "directory": "packages/test-utils"
  },
  "keywords": ["commonpub", "activitypub", "federation", "typescript", "testing", "factories"],
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=22" },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist/", "!dist/__tests__/", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@commonpub/schema": "workspace:*",
    "@commonpub/config": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
