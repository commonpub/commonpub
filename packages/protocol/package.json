{
  "name": "@commonpub/protocol",
  "version": "0.7.1",
  "type": "module",
  "description": "ActivityPub federation protocol — HTTP signatures, WebFinger, NodeInfo",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/commonpub/commonpub",
    "directory": "packages/protocol"
  },
  "keywords": ["commonpub", "activitypub", "federation", "typescript", "protocol", "http-signatures", "webfinger"],
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=22" },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist/", "!dist/__tests__/", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@commonpub/config": "workspace:*",
    "@commonpub/schema": "workspace:*",
    "jose": "^6.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
