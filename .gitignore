# Dependencies
node_modules/

# Build outputs
dist/
.svelte-kit/
build/
.nuxt/
.output/

# Turborepo
.turbo/

# Environment
.env
.env.local
.env.*.local
apps/**/.env
!apps/**/.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test
coverage/
test-results/
playwright-report/

# Local uploads (runtime-written files) — anchored so it does NOT also ignore
# the server/routes/uploads/ serving route.
/uploads/
apps/*/uploads/

# Rust
target/

# Stryker — narrowed to the mutation-report subdir (at any depth) so the bare
# `reports/` pattern stops swallowing real source dirs (e.g. the admin `reports/`
# API route). The leading `**/` keeps matching per-package `*/reports/mutation/`.
**/reports/mutation/
.stryker-tmp/

# Local test site
test-site/

# Design archive (Figma HTML exports, not used at runtime)
design-system-v2/

# Misc
*.log
*.tsbuildinfo

# Local secret backups (NEVER commit — operator-side .env material,
# per-instance keys for CPUB_FED_TOKEN_KEY / NUXT_AUTH_SECRET, etc.)
secrets/
.secrets/
*.secrets

# Claude Code user-local config (settings.local.json + scheduled tasks
# + per-user worktrees). Distinct from team-shared .claude/agents/ +
# .claude/commands/ which would be opt-in if/when we adopt them.
.claude/
