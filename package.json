{
  "name": "commonpub",
  "private": true,
  "type": "module",
  "description": "Open ActivityPub federation protocol and package suite for self-hosted maker communities",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:infra": "docker compose up -d",
    "dev:app": "turbo run dev --filter=@commonpub/reference",
    "db:push": "pnpm --filter @commonpub/schema db:push",
    "db:generate": "pnpm --filter @commonpub/schema drizzle-kit generate",
    "db:migrate": "pnpm --filter @commonpub/schema drizzle-kit migrate",
    "test": "turbo run test",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "publish:check": "pnpm build && pnpm typecheck && pnpm test",
    "publish:all": "pnpm -r --filter './packages/*' publish --no-git-checks",
    "stryker": "stryker run",
    "stryker:infra": "pnpm --filter @commonpub/infra exec stryker run",
    "stryker:schema": "pnpm --filter @commonpub/schema exec stryker run",
    "stryker:protocol": "pnpm --filter @commonpub/protocol exec stryker run",
    "stryker:editor": "pnpm --filter @commonpub/editor exec stryker run",
    "stryker:server": "pnpm --filter @commonpub/server exec stryker run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.50.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
